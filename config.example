# tuimux config — copy to ~/.config/tuimux/config and edit.
# All values are optional; sensible defaults apply when unset.

# Hosts to scan. Leave empty to auto-derive from `tailscale status`
# (machines you own that are online, plus this one).
# TUIMUX_HOSTS="macmini raluy splunk-server"

# Remote login user for Tailscale SSH. Defaults to your local $USER.
# TUIMUX_LOGIN="mduranfrigola"

# Per-host SSH usernames, for shared machines where your account isn't $USER.
# Space-separated host=user tokens; unmapped hosts fall back to TUIMUX_LOGIN.
# Manage it from the dashboard (press u) or with `tuimux login <host> <user>`.
# TUIMUX_LOGINS="herbert=mduran nebula=mduran"

# Session name used when you create one without naming it.
# TUIMUX_DEFAULT_SESSION="main"

# Per-host SSH connect timeout (seconds).
# TUIMUX_SSH_TIMEOUT=5

# Which terminal to drive when opening sessions in new tabs/windows. Auto-detected;
# set to force a driver. macOS: ghostty | terminal (Apple Terminal.app).
# Linux: gnome (GNOME Terminal) | custom (use TUIMUX_TERM_CMD) | generic.
# TUIMUX_TERM=ghostty

# Linux only — open sessions in ANY terminal via a command template. {cmd} is
# replaced with the (shell-quoted) command to run; wrap it for your terminal.
# Setting this selects the "custom" driver. Examples:
#   TUIMUX_TERM_CMD='kitty -e sh -c {cmd}'
#   TUIMUX_TERM_CMD='wezterm start -- sh -c {cmd}'
#   TUIMUX_TERM_CMD='alacritty -e sh -c {cmd}'

# Force the platform detection (normally from `uname`). Rarely needed; handy for
# testing the Linux launch paths from macOS. darwin | linux.
# TUIMUX_OS=linux

# Print the exact terminal-launch command instead of running it (debugging /
# dry-run). Any non-empty value enables it.
# TUIMUX_DRY_RUN=1

# TERM used for remote sessions. Ghostty's own terminfo (xterm-ghostty) usually
# isn't installed on other machines, which makes remote tmux abort; the default
# is the universally-present xterm-256color. (Local sessions keep your TERM.)
# TUIMUX_REMOTE_TERM=xterm-256color

# Pause (seconds) after opening a new tab/window before the command is sent to
# it. Lower = snappier opens; raise it only if the first keystrokes ever get
# dropped when opening a session on a slow machine.
# TUIMUX_SPAWN_DELAY=0.2

# Dashboard auto-refresh interval (seconds).
# TUIMUX_REFRESH=3

# How long the dashboard waits for one host's probe before showing it as "busy"
# (reachable but too loaded to answer in time). Probes run per-host and off the
# UI thread, so a slow host never blocks the rest.
# TUIMUX_PROBE_TIMEOUT=10

# How long a mutating action (detach/close/rename/keep-awake) may run.
# TUIMUX_ACTION_TIMEOUT=15

# How long host discovery (tailscale status) may run before giving up this tick.
# TUIMUX_HOSTS_TIMEOUT=8

# How long the terminal window/tab scan (used for the "OPEN IN" column) may run.
# TUIMUX_WINDOWS_TIMEOUT=5
